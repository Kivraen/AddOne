{
  "expo": {
    "name": "AddOne",
    "slug": "addone-app",
    "scheme": "addone",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "AddOne uses your local network during first-boot and recovery to send Wi-Fi credentials to your device."
      }
    }
  }
}
