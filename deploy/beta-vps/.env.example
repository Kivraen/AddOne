COMPOSE_PROJECT_NAME=addone-beta

# Public hostnames
GATEWAY_DOMAIN=gateway-beta.addone.studio
MQTT_DOMAIN=mqtt-beta.addone.studio

# Gateway container env
SUPABASE_URL=https://your-beta-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-beta-service-role-key
MQTT_TOPIC_PREFIX=addone
MQTT_QOS=1

# MQTT credentials used by the gateway and device fleet for beta
MQTT_GATEWAY_USERNAME=addone-beta-gateway
MQTT_GATEWAY_PASSWORD=replace-me
MQTT_DEVICE_USERNAME=device-fleet-beta
MQTT_DEVICE_PASSWORD=replace-me

# Email used by Caddy for certificate management on the HTTPS gateway
CADDY_EMAIL=hello@addone.studio
