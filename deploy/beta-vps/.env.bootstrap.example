COMPOSE_PROJECT_NAME=addone-beta

# Current hosted AddOne Supabase project, temporarily acting as beta
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

MQTT_TOPIC_PREFIX=addone
MQTT_QOS=1

# Public MQTT target for device beta firmware
MQTT_PUBLIC_HOST=72.62.200.12
MQTT_PUBLIC_PORT=8883

# Separate credentials for the gateway and the beta device fleet
MQTT_GATEWAY_USERNAME=addone-beta-gateway
MQTT_GATEWAY_PASSWORD=replace-me
MQTT_DEVICE_USERNAME=device-fleet-beta
MQTT_DEVICE_PASSWORD=replace-me
