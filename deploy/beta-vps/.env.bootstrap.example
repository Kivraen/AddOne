COMPOSE_PROJECT_NAME=addone-beta

# Current hosted AddOne Supabase project, temporarily acting as beta
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

MQTT_TOPIC_PREFIX=addone
MQTT_QOS=1

# Public MQTT target for device beta firmware
MQTT_PUBLIC_HOST=mqtt-beta.addone.studio
MQTT_PUBLIC_PORT=8883

# Dedicated gateway broker account. Keep `MQTT_GATEWAY_USERNAME` aligned with
# `mosquitto/acl.txt`. Device broker accounts are rendered from
# Supabase with `node ./mosquitto/render-passwords.mjs --env-file ./.env`.
MQTT_GATEWAY_USERNAME=addone-beta-gateway
MQTT_GATEWAY_PASSWORD=replace-me
MQTT_PASSWORD_SYNC_INTERVAL_MS=5000
